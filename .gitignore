# ==============================================================================
# NODE.JS & NPM
# ==============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package manager lock files (keep only one type)
# Uncomment the ones you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# NPM cache
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

